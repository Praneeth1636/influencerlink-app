# ─────────────────────────────────────────────────────────────────────
# Minimum to run locally:
#   DATABASE_URL, ENCRYPTION_KEY, NODE_ENV
# Everything else is required for specific features (auth, AI, search,
# payments, etc). Features should fail gracefully when their vars are
# unset — e.g. AI button shows "disabled" instead of crashing.
# ─────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# AI
ANTHROPIC_API_KEY=""

# Social platform integrations
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
YOUTUBE_API_KEY=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET=""
R2_BUCKET=""

# Supabase Realtime
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE=""

# Search
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""

# Jobs and email
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
RESEND_API_KEY=""

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
LOG_LEVEL="info"

# Security
# 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Local prototype DB. Remove once all routes migrate to Drizzle.
INFLUENCERLINK_DB_PATH=""