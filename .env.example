# ─────────────────────────────────────────────────────────────────────
# Minimum to run locally:
#   DATABASE_URL, ENCRYPTION_KEY, NODE_ENV
# Everything else is required for specific features (auth, AI, search,
# payments, etc). Features should fail gracefully when their vars are
# unset — e.g. AI button shows "disabled" instead of crashing.
# ─────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/terrace?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/terrace?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# AI embeddings
# Leave both blank to use the deterministic local embedder for dev/demo.
OPENAI_API_KEY=""
VOYAGE_API_KEY=""
USE_LOCAL_EMBEDDER="true"

# Social platform integrations
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_REDIRECT_URI="http://localhost:3000/api/auth/instagram/callback"
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3000/api/auth/tiktok/callback"
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/auth/youtube/callback"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="Terrace <notifications@influencerlink.app>"
EMAIL_REPLY_TO="support@terrace.app"

# Rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
LOG_LEVEL="info"

# Security
# 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace_with_64_hex_chars_from_openssl_rand_hex_32"
CRON_SECRET=""

NODE_ENV="development"
E2E_BYPASS_AUTH="false"
